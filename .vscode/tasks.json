{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Package: PyInstaller",
      "type": "shell",
      "command": "pyinstaller",
      "args": [
        "--name", "Commander",
        "--onefile",
        "--windowed",
        "--icon", "commander/assets/logo.png",
        "--add-data", "commander/assets;commander/assets",
        "--hidden-import", "pystray._win32",
        "--hidden-import", "pkg_resources.py2_warn",
        "--collect-all", "speechmatics",
        "--collect-all", "speechmatics_rt",
        "--collect-all", "pynput",
        "main.py"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Package: PyInstaller (folder)",
      "type": "shell",
      "command": "pyinstaller",
      "args": [
        "--name", "Commander",
        "--onedir",
        "--windowed",
        "--icon", "commander/assets/logo.png",
        "--add-data", "commander/assets;commander/assets",
        "--hidden-import", "pystray._win32",
        "--hidden-import", "pkg_resources.py2_warn",
        "--collect-all", "speechmatics",
        "--collect-all", "speechmatics_rt",
        "--collect-all", "pynput",
        "main.py"
      ],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": true
      },
      "problemMatcher": []
    }
  ]
}
